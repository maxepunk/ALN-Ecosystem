{
  "kind": "game",
  "schemaVersion": 1,
  "id": "about-last-night",
  "title": "About Last Night",

  "modes": [
    {
      "id": "blackmarket",
      "label": "Black Market",
      "verb": "Sell",
      "scoringPolicy": "standard",
      "entityRole": "ledger",
      "countsTowardGroups": true,
      "displayBehavior": {
        "surface": "scoreboard-rankings",
        "when": "immediate"
      }
    },
    {
      "id": "detective",
      "label": "Detective",
      "verb": "Expose",
      "scoringPolicy": "none",
      "entityRole": "attribution",
      "defaultEntity": "Nova",
      "countsTowardGroups": false,
      "displayBehavior": {
        "surface": "scoreboard-evidence",
        "fields": ["summary", "owner"],
        "when": "immediate"
      }
    }
  ],

  "scoring": {
    "baseValues": { "1": 10000, "2": 25000, "3": 50000, "4": 75000, "5": 150000 },
    "typeMultipliers": { "Personal": 1, "Mention": 3, "Business": 3, "Party": 5, "Technical": 5, "UNKNOWN": 0 },
    "display": { "unit": "currency-usd", "format": "$#,###" },
    "semantics": { "allowNegative": true }
  },

  "groupRules": {
    "type": "all",
    "minSize": 2,
    "completion": { "bonusFormula": "multiplier-minus-one-times-base" }
  },

  "duplicatePolicy": {
    "claim": "once",
    "view": "unlimited"
  },

  "entities": {
    "label": { "singular": "Account", "plural": "Accounts" },
    "creation": "freeform-at-action",
    "membership": "untracked"
  },

  "functions": {
    "view-content": { "classes": ["personal", "station", "staffed"] },
    "transact": { "classes": ["staffed"], "modes": ["blackmarket", "detective"] },
    "entity-binding": { "classes": [] },
    "session-lifecycle": { "classes": ["staffed"] },
    "show-control": { "classes": ["staffed"] },
    "score-intervention": { "classes": ["staffed"] },
    "report-intake": { "classes": ["staffed"] }
  },

  "gameClock": {
    "duration": 7200,
    "overtimeAt": 7200,
    "phases": [
      { "id": "main", "label": "Game", "start": { "at": 0 } }
    ]
  }
}
